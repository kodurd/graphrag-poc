# Скопируйте в .env и заполните. .env в .gitignore.

# --- Neo4j ---
NEO4J_PASSWORD=graphrag-local

# --- LLM (дев: API; локальный прогон: Ollama, см. config/settings.yaml) ---
# OpenAI-совместимый эндпоинт. Для другого провайдера поменяйте llm.api_base в settings.yaml.
LLM_API_KEY=sk-...

# Ollama обычно не требует ключа; base задаётся в settings.yaml (llm.ollama_base).
